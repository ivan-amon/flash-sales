# ---------------------------------------------------------------------------
# Production environment for the Droplet.
# Copy to `.env` on the server and fill in every value. NEVER commit the real
# file. This single file is read both by Docker Compose (for ${VARS} in
# compose.prod.yaml) and by the Laravel containers (env_file).
# ---------------------------------------------------------------------------

APP_NAME="Flash Sales"
APP_ENV=production
# Generate with: docker compose -f compose.prod.yaml run --rm api php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://flash-sales.ivanamon.dev
FRONTEND_URL=https://flash-sales.ivanamon.dev

# Domain Caddy will request a TLS certificate for
APP_DOMAIN=flash-sales.ivanamon.dev

# Container images built and pushed by CI (replace OWNER with your GitHub user/org, lowercase)
API_IMAGE=ghcr.io/OWNER/flash-sales-api:latest
FRONTEND_IMAGE=ghcr.io/OWNER/flash-sales-frontend:latest

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database (mysql service)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flash_sales
DB_USERNAME=flash_sales
DB_PASSWORD=CHANGE_ME_STRONG
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT

# Redis (redis service)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# Mail (Resend) — verify ivanamon.dev in Resend and use a sender on that domain
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@ivanamon.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Stripe (test keys are fine for the portfolio)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CURRENCY=eur
